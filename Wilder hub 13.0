-- ATOMIC TORNADO - Auto segurar Brainrot
local atomicHolding = false
local function fAutoHoldBrainrot(on)
    stopLoop("atomichold"); if not on then return end
    loops["atomichold"] = RS.Stepped:Connect(function()
        local tornado = findObj({"tornado","atomic","atom","storm","nado"})
        if not tornado then return end
        local h = getHRP()
        if h and (h.Position - getPos(tornado)).Magnitude < 50 then
            if not atomicHolding then
                atomicHolding = true
                local prompt = tornado:FindFirstChildOfClass("ProximityPrompt")
                if prompt then fireproximityprompt(prompt) end
                setStat("Segurando Brainrot no Atomic Tornado!", C.am)
                task.wait(3.5)
                atomicHolding = false
            end
        end
    end)
    setStat("Auto Hold Brainrot ON — use no evento!", C.vd)
end

