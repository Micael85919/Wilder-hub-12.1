-- ============================================================
-- HELPERS UI
-- ============================================================
local function cr(f, r)
    Instance.new("UICorner", f).CornerRadius = UDim.new(0, r or 6)
end
local function gr(f, a, b)
    local g = Instance.new("UIGradient", f)
    g.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, a),
        ColorSequenceKeypoint.new(1, b)
    })
end
local function mk(f, col, th)
    local s = Instance.new("UIStroke", f)
    s.Color = col; s.Thickness = th or 1.5
    return s
end
local function lbl(p, t, ts, col, fn, zi)
    local l = Instance.new("TextLabel", p)
    l.BackgroundTransparency = 1
    l.Text = t
    l.TextSize = ts or 11
    l.TextColor3 = col or C.br
    l.Font = fn or Enum.Font.Gotham
    l.ZIndex = zi or 13
    return l
end

-- ============================================================
-- HELPERS JOGO
-- ============================================================
local function getChar()  return LP.Character end
local function getHRP()   local c = getChar(); return c and c:FindFirstChild("HumanoidRootPart") end
local function getHum()   local c = getChar(); return c and c:FindFirstChildOfClass("Humanoid") end
local function getPos(o)
    if not o then return nil end
    if o:IsA("Model") and o.PrimaryPart then return o.PrimaryPart.Position
    elseif o:IsA("BasePart") then return o.Position end
end
local function tpTo(pos)
    local h = getHRP()
    if h and pos then h.CFrame = CFrame.new(pos + Vector3.new(0, 4, 0)) end
end
local function findObj(kws)
    for _, o in pairs(workspace:GetDescendants()) do
        local n = o.Name:lower()
        for _, k in pairs(kws) do
            if n:find(k) then return o end
        end
    end
end
local function activateObj(o)
    if not o then return end
    pcall(function()
        local pp = o:FindFirstChildOfClass("ProximityPrompt")
            or (o.Parent and o.Parent:FindFirstChildOfClass("ProximityPrompt"))
        if pp then fireproximityprompt(pp) end
    end)
    pcall(function()
        if o:IsA("BasePart") then
            local cd = o:FindFirstChildOfClass("ClickDetector")
            if cd then fireclickdetector(cd) end
        end
    end)
end

local loops = {}
local function stopLoop(name)
    if loops[name] then loops[name]:Disconnect(); loops[name] = nil end
end

local toggleStates = {}
local allSearchItems = {}  -- para pesquisa global
local setStat  -- forward declaration

