-- AUTO FARM EVENTO ATIVO (GERAL)
local function autoFarmEventoAtivo()
    while toggleStates["Auto Farm Evento Ativo"] do
        local eventZone = findObj({"event","admin_abuse","lucky_block","coral","luke","taco","tomato","atomic","tornado","mole","pickup"})
        if eventZone then
            tpTo(getPos(eventZone))
            task.wait(0.5)
            for _, obj in pairs(workspace:GetDescendants()) do
                if obj.Name:lower():find("brainrot") or obj.Name:lower():find("coin") or obj.Name:lower():find("token") then
                    local pos = getPos(obj)
                    if pos and (getHRP().Position - pos).Magnitude < 150 then
                        tpTo(pos)
                        activateObj(obj)
                        task.wait(0.1)
                    end
                end
            end
        end
        task.wait(2)
    end
end

-- AUTO SPIN WHEEL (ROLETA)
local function autoSpinWheel()
    while toggleStates["Auto Spin Wheel"] do
        local wheel = findObj({"wheel","spinner","roulette","roleta","giratorio"})
        if wheel then
            tpTo(getPos(wheel))
            task.wait(0.5)
            local prompt = wheel:FindFirstChildOfClass("ProximityPrompt")
            if prompt then
                fireproximityprompt(prompt)
                setStat("Girando a roleta...", C.am)
                task.wait(2)
            else
                local click = wheel:FindFirstChildOfClass("ClickDetector")
                if click then fireclickdetector(click); task.wait(2) end
            end
        else
            task.wait(5)
        end
    end
end

