-- MINING EVENT (ORIGINAL)
local function fMining(on)
    stopLoop("mine"); if not on then return end
    spawn(function()
        while toggleStates["Auto Mining"] do
            local h = getHRP()
            if h then
                local best, bestDist = nil, 999
                for _, o in pairs(workspace:GetDescendants()) do
                    local n = o.Name:lower()
                    if n:find("rock") or n:find("ore") or n:find("gem") or n:find("mineral") or n:find("vein") then
                        local pos = getPos(o)
                        if pos then
                            local d = (h.Position - pos).Magnitude
                            if d < bestDist then bestDist = d; best = {o = o, p = pos} end
                        end
                    end
                end
                if best then
                    h.CFrame = CFrame.new(best.p + Vector3.new(0, 3, 0))
                    task.wait(0.15); activateObj(best.o)
                    task.wait(0.3)
                    for _, o in pairs(workspace:GetDescendants()) do
                        local n = o.Name:lower()
                        if n:find("gem") or n:find("drop") or n:find("crystal") then
                            local pos = getPos(o)
                            if pos then
                                local h2 = getHRP()
                                if h2 then
                                    h2.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0))
                                    activateObj(o)
                                end
                            end
                        end
                    end
                end
            end
            task.wait(1)
        end
    end)
end

-- CANCEL TSUNAMI (ORIGINAL)
local cancelTsConn = nil
local function fCancelTs(on)
    if cancelTsConn then cancelTsConn:Disconnect(); cancelTsConn = nil end
    if not on then setStat("Cancel Tsunami OFF", C.vm); return end
    local waveKws = {"tsunami","wave","flood","tidal","bunny","rabbit"}
    local function removeWaves()
        for _, o in pairs(workspace:GetDescendants()) do
            local n = o.Name:lower()
            for _, k in pairs(waveKws) do
                if n:find(k) then
                    if o:IsA("BasePart") then
                        pcall(function() o.CanCollide = false; o.Transparency = 1; o.CFrame = CFrame.new(0,-9999,0) end)
                    elseif o:IsA("Model") then
                        for _, p in pairs(o:GetDescendants()) do
                            if p:IsA("BasePart") then
                                pcall(function() p.CanCollide = false; p.Transparency = 1; p.CFrame = CFrame.new(0,-9999,0) end)
                            end
                        end
                    end
                end
            end
        end
    end
    removeWaves()
    cancelTsConn = RS.Stepped:Connect(removeWaves)
    setStat("Tsunami CANCELADO — ondas removidas!", C.vd)
end

-- AUTO ESCAPE (ORIGINAL)
local function fAutoEscape(on)
    stopLoop("esc"); if not on then return end
    loops["esc"] = RS.Stepped:Connect(function()
        local h = getHRP(); if not h then return end
        local wave = workspace:FindFirstChild("Tsunami") or workspace:FindFirstChild("Wave")
            or findObj({"tsunami","wave","flood","bunny"})
        if wave then
            local wp = wave:IsA("Model") and wave.PrimaryPart or (wave:IsA("BasePart") and wave)
            if wp and wp:IsA("BasePart") and (h.Position - wp.Position).Magnitude < 240 then
                local dir = (h.Position - wp.Position).Unit
                h.CFrame = h.CFrame + (dir * 150)
                setStat("Fugindo da onda!", C.vm)
            end
        end
    end)
end

-- FLY NORMAL (ORIGINAL)
local flyNormConn = nil
local function stopFlyNorm()
    if flyNormConn then flyNormConn:Disconnect(); flyNormConn = nil end
    local h = getHRP()
    if h then
        local bg = h:FindFirstChild("WHBg"); if bg then bg:Destroy() end
        local bv = h:FindFirstChild("WHBv"); if bv then bv:Destroy() end
    end
    local hm = getHum(); if hm then hm.PlatformStand = false end
    local fu = SG:FindFirstChild("FlyUI"); if fu then fu:Destroy() end
end
local function fFlyNorm(on)
    stopFlyNorm(); if not on then setStat("Fly OFF", C.vm); return end
    local h = getHRP(); if not h then return end
    local hm = getHum(); if hm then hm.PlatformStand = true end
    local bg = Instance.new("BodyGyro", h); bg.Name = "WHBg"; bg.MaxTorque = Vector3.new(9e9,9e9,9e9); bg.D = 100; bg.P = 1e5
    local bv = Instance.new("BodyVelocity", h); bv.Name = "WHBv"; bv.MaxForce = Vector3.new(9e9,9e9,9e9); bv.Velocity = Vector3.new()
    local fu = Instance.new("Frame", SG); fu.Name = "FlyUI"; fu.Size = UDim2.new(0,190,0,108); fu.Position = UDim2.new(0.5,-95,1,-128); fu.BackgroundTransparency = 1; fu.ZIndex = 30
    local held = {}
    for _, d in pairs({{"Subir",0.37,0,Vector3.new(0,1,0)},{"Descer",0.37,0.65,Vector3.new(0,-1,0)},{"Esq",0,0.32,"left"},{"Dir",0.72,0.32,"right"},{"Frente",0.37,0.32,"front"}}) do
        local b = Instance.new("TextButton",fu); b.Size=UDim2.new(0,54,0,30); b.Position=UDim2.new(d[2],0,d[3],0); b.BackgroundColor3=C.rx; b.Text=d[1]; b.TextColor3=C.br; b.TextSize=10; b.Font=Enum.Font.GothamBold; b.BorderSizePixel=0; b.ZIndex=31; cr(b,6)
        b.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseButton1 then held[d[1]]=d[4] end end)
        b.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseButton1 then held[d[1]]=nil end end)
    end
    local sb = Instance.new("TextButton",fu); sb.Size=UDim2.new(1,0,0,22); sb.Position=UDim2.new(0,0,1,-24); sb.BackgroundColor3=C.rx; sb.Text="PARAR FLY"; sb.TextColor3=C.br; sb.TextSize=10; sb.Font=Enum.Font.GothamBold; sb.BorderSizePixel=0; sb.ZIndex=31; cr(sb,5)
    sb.MouseButton1Click:Connect(function() toggleStates["Fly"]=false; stopFlyNorm(); setStat("Fly OFF",C.vm) end)
    flyNormConn = RS.Heartbeat:Connect(function()
        local h2 = getHRP(); if not h2 then stopFlyNorm(); return end
        local bv2 = h2:FindFirstChild("WHBv"); local bg2 = h2:FindFirstChild("WHBg"); if not bv2 or not bg2 then return end
        local cam = workspace.CurrentCamera; local dir = Vector3.new()
        for _, v in pairs(held) do
            if type(v) == "userdata" then dir = dir + v
            elseif v == "front" then dir = dir + cam.CFrame.LookVector
            elseif v == "left" then dir = dir - cam.CFrame.RightVector
            elseif v == "right" then dir = dir + cam.CFrame.RightVector end
        end
        if UIS:IsKeyDown(Enum.KeyCode.W) then dir = dir + cam.CFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.S) then dir = dir - cam.CFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.A) then dir = dir - cam.CFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.D) then dir = dir + cam.CFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.Space)     then dir = dir + Vector3.new(0,1,0) end
        if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then dir = dir - Vector3.new(0,1,0) end
        bv2.Velocity = dir.Magnitude > 0 and dir.Unit * 62 or Vector3.new()
        bg2.CFrame   = cam.CFrame
    end)
    setStat("Fly ON! Use botoes ou WASD", C.vd)
end

-- FULLBRIGHT (ORIGINAL)
local function fFullBright(on)
    if on then LT.Brightness=10; LT.ClockTime=14; LT.FogEnd=1e9; LT.GlobalShadows=false; LT.Ambient=Color3.fromRGB(255,255,255)
    else LT.Brightness=2; LT.ClockTime=14; LT.FogEnd=100000; LT.GlobalShadows=true; LT.Ambient=Color3.fromRGB(100,100,100) end
    setStat(on and "FullBright ON" or "FullBright OFF", on and C.vd or C.vm)
end

-- NOCLIP (ORIGINAL)
local function fNoclip(on)
    stopLoop("nc"); if not on then return end
    loops["nc"] = RS.Stepped:Connect(function()
        local c = getChar(); if not c then return end
        for _, p in pairs(c:GetDescendants()) do
            if p:IsA("BasePart") then p.CanCollide = false end
        end
    end)
end

-- INFINITE JUMP (ORIGINAL)
local function fInfJump(on)
    stopLoop("ij"); if not on then return end
    loops["ij"] = UIS.JumpRequest:Connect(function()
        local hm = getHum(); if hm then hm:ChangeState(Enum.HumanoidStateType.Jumping) end
    end)
end

-- ESP (ORIGINAL)
local function fESP(on)
    if not on then
        for _, p in pairs(game:GetService("Players"):GetPlayers()) do
            if p ~= LP and p.Character then
                local bb = p.Character:FindFirstChild("WHESP"); if bb then bb:Destroy() end
            end
        end; return
    end
    local function addESP(p)
        if not p.Character then p.CharacterAdded:Wait() end
        local c = p.Character; if not c then return end
        local bb = Instance.new("BillboardGui", c); bb.Name="WHESP"; bb.Size=UDim2.new(0,100,0,26); bb.StudsOffset=Vector3.new(0,3,0); bb.AlwaysOnTop=true
        local l = lbl(bb, p.Name, 10, C.dt, Enum.Font.GothamBold, 1)
        l.Size=UDim2.new(1,0,1,0); l.BackgroundColor3=Color3.new(0,0,0); l.BackgroundTransparency=0.6; cr(l,4)
    end
    for _, p in pairs(game:GetService("Players"):GetPlayers()) do
        if p ~= LP then spawn(function() addESP(p) end) end
    end
end

-- ANTI-BAC (ORIGINAL)
local function startAntiBAC()
    spawn(function()
        while true do
            task.wait(38 + math.random(1, 26))
            if toggleStates["Anti-Deteccao"] then
                local hm = getHum()
                if hm and math.random(1, 3) == 1 then
                    hm.Jump = true
                    task.delay(0.06 + math.random() * 0.05, function()
                        if hm then hm.Jump = false end
                    end)
                end
            end
        end
    end)
end

