local function fAutoPickupCollector(on)
    stopLoop("pickupcollector"); if not on then return end
    loops["pickupcollector"] = RS.Stepped:Connect(function()
        local h = getHRP(); if not h then return end
        for _, o in pairs(workspace:GetDescendants()) do
            local n = o.Name:lower()
            if n:find("mole") or n:find("pit") or n:find("pickup") or n:find("hole") or n:find("burrow") then
                local pos = getPos(o)
                if pos and (h.Position - pos).Magnitude < 150 then
                    h.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0))
                    activateObj(o)
                end
            end
        end
    end)
    setStat("Auto Pickup Collector ON — coletando mole pits!", C.vd)
end

