-- ============================================================
-- FAB CLIQUE: ABRE/FECHA MENU
-- ============================================================
FBTN.MouseButton1Click:Connect(function()
    if fabMoved then return end
    menuOpen = not menuOpen
    Menu.Visible = menuOpen
    if menuOpen then
        local fp = FAB.AbsolutePosition
        local ss = SG.AbsoluteSize
        local mx = fp.X + 56
        local my = fp.Y - 10
        if mx + 370 > ss.X then mx = fp.X - 376 end
        if my + 420 > ss.Y then my = ss.Y - 430 end
        if my < 0 then my = 4 end
        Menu.Position = UDim2.new(0, mx, 0, my)
        showPage("Protecao")
        local fb = sideButtons["Protecao"]
        if fb then
            local ind = fb:FindFirstChildOfClass("Frame")
            if ind then ind.Visible = true end
        end
    end
end)

-- ============================================================
-- VERIFICACAO DE KEY
-- ============================================================
local function verifyKey()
    local key = kBox.Text:gsub("%s", "")
    if key == KEY then
        kMsg.Text      = "Key correta!"
        kMsg.TextColor3 = C.vd
        task.wait(0.7)
        TS:Create(KBG, TweenInfo.new(0.45), {BackgroundTransparency = 1}):Play()
        for _, v in pairs(KBG:GetDescendants()) do
            if v:IsA("GuiObject") then
                TS:Create(v, TweenInfo.new(0.35), {BackgroundTransparency = 1}):Play()
                if v:IsA("TextLabel") or v:IsA("TextButton") or v:IsA("TextBox") then
                    TS:Create(v, TweenInfo.new(0.35), {TextTransparency = 1}):Play()
                end
            end
        end
        task.wait(0.4)
        KBG.Visible  = false
        FAB.Visible  = true
        setStat("Toque em W para abrir o menu!", C.vd)
        startAntiBAC()
    else
        kMsg.Text      = "Key incorreta! Pegue no Discord."
        kMsg.TextColor3 = C.vm
        local orig = KP.Position
        for _ = 1, 4 do
            KP.Position = UDim2.new(orig.X.Scale, orig.X.Offset + 8, orig.Y.Scale, orig.Y.Offset)
            task.wait(0.05)
            KP.Position = UDim2.new(orig.X.Scale, orig.X.Offset - 8, orig.Y.Scale, orig.Y.Offset)
            task.wait(0.05)
        end
        KP.Position = orig
    end
end

kConfBtn.MouseButton1Click:Connect(verifyKey)
kBox.FocusLost:Connect(function(entered)
    if entered then verifyKey() end
end)

showPage("Protecao")
print("Wider Hub "..VER.." | v13.0 | 26/04/2026 | Carregado com todas as novidades de Abril e correções!")
