-- FISHING LTM (ORIGINAL)
local function fFishing(on)
    stopLoop("fish"); if not on then return end
    loops["fish"] = RS.Stepped:Connect(function()
        local h = getHRP(); if not h then return end
        for _, o in pairs(workspace:GetDescendants()) do
            local n = o.Name:lower()
            if n:find("fish") or n:find("pesca") or n:find("rod") or n:find("catch") or n:find("bait") then
                local pos = getPos(o)
                if pos and (h.Position - pos).Magnitude < 120 then
                    h.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0))
                    activateObj(o)
                end
            end
        end
