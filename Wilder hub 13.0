srchBox:GetPropertyChangedSignal("Text"):Connect(function()
    local q = srchBox.Text:lower():gsub("%s","")
    if #q == 0 then
        if curPage ~= "" then showPage(curPage) end
        return
    end
    for _, ch in pairs(ContentScroll:GetChildren()) do
        if ch:IsA("GuiObject") and ch ~= ContentLayout then ch:Destroy() end
    end
    for _, item in pairs(allSearchItems) do
        local n = (item.name or ""):lower():gsub("%s","")
        local d = (item.desc or ""):lower():gsub("%s","")
        if n:find(q) or d:find(q) then item.fn() end
    end
    for _, b in pairs(sideButtons) do b.BackgroundTransparency = 1 end
end)

