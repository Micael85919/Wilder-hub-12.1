-- ============================================================
-- SISTEMA DE PAGINAS
-- ============================================================
local function showPage(name)
    for _, ch in pairs(ContentScroll:GetChildren()) do
        if ch:IsA("GuiObject") and ch ~= ContentLayout then
            ch:Destroy()
        end
    end
    for k, b in pairs(sideButtons) do
        if k == name then
            b.BackgroundColor3 = C.sel
            b.BackgroundTransparency = 0
        else
            b.BackgroundTransparency = 1
        end
    end
    curPage = name
    if pages[name] then
        for _, fn in pairs(pages[name]) do
            fn()
        end
    end
end

local function addSideBtn(name, icon)
    local btn = Instance.new("TextButton", SideScroll)
    btn.Size = UDim2.new(1, 0, 0, 44)
    btn.BackgroundColor3 = C.sb
    btn.BackgroundTransparency = 1
    btn.Text = ""
    btn.BorderSizePixel = 0
    btn.ZIndex = 13

    local indicator = Instance.new("Frame", btn)
    indicator.Size = UDim2.new(0, 3, 0.6, 0)
    indicator.Position = UDim2.new(0, 0, 0.2, 0)
    indicator.BackgroundColor3 = C.dt
    indicator.BorderSizePixel = 0
    indicator.Visible = false
    indicator.ZIndex = 14
    cr(indicator, 2)

    local iconLbl = lbl(btn, icon, 12, C.tx, Enum.Font.GothamBold, 14)
    iconLbl.Size = UDim2.new(1, 0, 0, 20)
    iconLbl.Position = UDim2.new(0, 0, 0, 5)

    local nameLbl = lbl(btn, name, 8, C.txs, Enum.Font.Gotham, 14)
    nameLbl.Size = UDim2.new(1, -2, 0, 16)
    nameLbl.Position = UDim2.new(0, 2, 0, 24)
    nameLbl.TextWrapped = true

    sideButtons[name] = btn
    btn.MouseButton1Click:Connect(function()
        showPage(name)
        indicator.Visible = true
        iconLbl.TextColor3 = C.br
        nameLbl.TextColor3 = C.tx
        for k2, b2 in pairs(sideButtons) do
            if k2 ~= name then
                local ind2 = b2:FindFirstChildOfClass("Frame")
                if ind2 then
                    ind2.Visible = false
                end
            end
        end
    end)
end

local function addSection(title)
    pages[curPage][#pages[curPage] + 1] = function()
        local f = Instance.new("Frame", ContentScroll)
        f.Size = UDim2.new(1, 0, 0, 24)
        f.BackgroundColor3 = C.rxe
        f.BorderSizePixel = 0
        f.ZIndex = 13
        gr(f, C.rxe, C.ct)
        local l = lbl(f, title, 10, C.br, Enum.Font.GothamBold, 14)
        l.Size = UDim2.new(1, -8, 1, 0)
        l.Position = UDim2.new(0, 6, 0, 0)
        l.TextXAlignment = Enum.TextXAlignment.Left
    end
end

local function addToggle(name, desc, callback)
    toggleStates[name] = false
    local function renderFn()
        local f = Instance.new("Frame", ContentScroll)
        f.Size = UDim2.new(1, 0, 0, 50)
        f.BackgroundTransparency = 1
        f.BorderSizePixel = 0
        f.ZIndex = 13

        local divLine = Instance.new("Frame", f)
        divLine.Size = UDim2.new(1, -12, 0, 1)
        divLine.Position = UDim2.new(0, 6, 1, -1)
        divLine.BackgroundColor3 = C.div
        divLine.BorderSizePixel = 0
        divLine.ZIndex = 14

        local nameLbl = lbl(f, name, 11, C.br, Enum.Font.GothamBold, 14)
        nameLbl.Size = UDim2.new(1, -52, 0, 18)
        nameLbl.Position = UDim2.new(0, 8, 0, 6)
        nameLbl.TextXAlignment = Enum.TextXAlignment.Left

        local descLbl = lbl(f, desc or "", 8, C.txs, Enum.Font.Gotham, 14)
        descLbl.Size = UDim2.new(1, -52, 0, 20)
        descLbl.Position = UDim2.new(0, 8, 0, 24)
        descLbl.TextXAlignment = Enum.TextXAlignment.Left
        descLbl.TextWrapped = true

        local pill = Instance.new("TextButton", f)
        pill.Size = UDim2.new(0, 40, 0, 20)
        pill.Position = UDim2.new(1, -46, 0.5, -10)
        pill.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
        pill.Text = ""
        pill.BorderSizePixel = 0
        pill.ZIndex = 14
        cr(pill, 10)

        local knob = Instance.new("Frame", pill)
        knob.Size = UDim2.new(0, 16, 0, 16)
        knob.Position = UDim2.new(0, 2, 0.5, -8)
        knob.BackgroundColor3 = C.gz2
        knob.BorderSizePixel = 0
        knob.ZIndex = 15
        cr(knob, 8)

        pill.MouseButton1Click:Connect(function()
            toggleStates[name] = not toggleStates[name]
            if toggleStates[name] then
                pill.BackgroundColor3 = C.dt
                TS:Create(knob, TweenInfo.new(0.15), {
                    Position = UDim2.new(1, -18, 0.5, -8),
                    BackgroundColor3 = C.br
                }):Play()
                setStat(name .. " ON", C.vd)
            else
                pill.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
                TS:Create(knob, TweenInfo.new(0.15), {
                    Position = UDim2.new(0, 2, 0.5, -8),
                    BackgroundColor3 = C.gz2
                }):Play()
                setStat(name .. " OFF", C.vm)
            end
            if callback then
                pcall(callback, toggleStates[name])
            end
        end)
    end
    pages[curPage][#pages[curPage] + 1] = renderFn
    allSearchItems[#allSearchItems + 1] = {
        name = name,
        desc = desc,
        fn = renderFn
    }
end

local function addButton(name, desc, callback)
    local function renderFn()
        local f = Instance.new("Frame", ContentScroll)
        f.Size = UDim2.new(1, 0, 0, 50)
        f.BackgroundTransparency = 1
        f.BorderSizePixel = 0
        f.ZIndex = 13

        local divLine = Instance.new("Frame", f)
        divLine.Size = UDim2.new(1, -12, 0, 1)
        divLine.Position = UDim2.new(0, 6, 1, -1)
        divLine.BackgroundColor3 = C.div
        divLine.BorderSizePixel = 0
        divLine.ZIndex = 14

        local btn = Instance.new("TextButton", f)
        btn.Size = UDim2.new(1, 0, 1, 0)
        btn.BackgroundTransparency = 1
        btn.Text = ""
        btn.BorderSizePixel = 0
        btn.ZIndex = 14

        local nameLbl = lbl(btn, name, 11, C.br, Enum.Font.GothamBold, 15)
        nameLbl.Size = UDim2.new(1, -36, 0, 18)
        nameLbl.Position = UDim2.new(0, 8, 0, 6)
        nameLbl.TextXAlignment = Enum.TextXAlignment.Left

        local descLbl = lbl(btn, desc or "", 8, C.txs, Enum.Font.Gotham, 15)
        descLbl.Size = UDim2.new(1, -36, 0, 20)
        descLbl.Position = UDim2.new(0, 8, 0, 24)
        descLbl.TextXAlignment = Enum.TextXAlignment.Left
        descLbl.TextWrapped = true

        local arrow = lbl(btn, ">", 13, C.dt, Enum.Font.GothamBold, 15)
        arrow.Size = UDim2.new(0, 20, 0, 20)
        arrow.Position = UDim2.new(1, -26, 0.5, -10)

        btn.MouseButton1Click:Connect(function()
            setStat("Executando: " .. name, C.am)
            f.BackgroundTransparency = 0
            f.BackgroundColor3 = C.sel
            task.delay(0.12, function()
                f.BackgroundTransparency = 1
            end)
            if callback then
                pcall(callback)
            end
        end)
    end
    pages[curPage][#pages[curPage] + 1] = renderFn
    allSearchItems[#allSearchItems + 1] = {
        name = name,
        desc = desc,
        fn = renderFn
    }
end

-- ============================================================
-- FUNCOES DO JOGO (ORIGINAIS + NOVAS)
-- ============================================================

-- ============================================================
-- FARM SUBTERRANEO (ORIGINAL)
-- ============================================================
local subFarmConn = nil
local SUB_Y = -7
local farmSpeed = 2
local SPEED_TABLE = {0.4, 0.2, 0.1, 0.06, 0.03}

local function fSubFarm(on)
    if subFarmConn then subFarmConn:Disconnect(); subFarmConn = nil end
    if not on then setStat("Farm Subterraneo OFF", C.vm); return end
    local farmKws = {
        "brainrot","common","uncommon","rare","epic","legendary","mythic",
        "cosmic","secret","celestial","divine","infinity","paradox",
        "phantom","orb","coin","shard","egg","spring","golden",
        "lucky","block","fish","ore","gem","crystal"
    }
    local collecting = false
    subFarmConn = RS.Stepped:Connect(function()
        local h = getHRP(); if not h then return end
        if collecting then return end
        if math.abs(h.Position.Y - SUB_Y) > 1.5 then
            pcall(function() h.CFrame = CFrame.new(h.Position.X, SUB_Y, h.Position.Z) end)
        end
        local bestItem, bestDist = nil, 200
        for _, o in pairs(WS:GetDescendants()) do
            local n = o.Name:lower()
            for _, k in pairs(farmKws) do
                if n:find(k) then
                    local pos = getPos(o)
                    if pos then
                        local xzDist = Vector2.new(h.Position.X - pos.X, h.Position.Z - pos.Z).Magnitude
                        if xzDist < bestDist then bestDist = xzDist; bestItem = {o=o, p=pos} end
                    end; break
                end
            end
        end
        if bestItem then
            collecting = true
            spawn(function()
                local delay = SPEED_TABLE[farmSpeed] or 0.2
                local h2 = getHRP(); if not h2 then collecting=false; return end
                h2.CFrame = CFrame.new(bestItem.p.X, SUB_Y, bestItem.p.Z)
                task.wait(delay)
                local h3 = getHRP(); if not h3 then collecting=false; return end
                h3.CFrame = CFrame.new(bestItem.p.X, 4, bestItem.p.Z)
                task.wait(delay * 0.5); activateObj(bestItem.o)
                task.wait(delay * 0.3)
                local h4 = getHRP(); if not h4 then collecting=false; return end
                h4.CFrame = CFrame.new(bestItem.p.X, SUB_Y, bestItem.p.Z)
                task.wait(delay)
                local base = findObj({"base","plot","spawn","homebase"})
                local bp = getPos(base)
                local h5 = getHRP()
                if h5 and bp then
                    h5.CFrame = CFrame.new(bp.X, SUB_Y, bp.Z)
                    task.wait(delay * 0.5)
                    local h6 = getHRP()
                    if h6 then h6.CFrame = CFrame.new(bp.X, 4, bp.Z) end
                    task.wait(delay * 0.3); activateObj(base)
                    task.wait(delay * 0.3)
                    local h7 = getHRP()
                    if h7 then h7.CFrame = CFrame.new(bp.X, SUB_Y, bp.Z) end
                end
                setStat("Coletado! Velocidade: "..farmSpeed, C.vd)
                collecting = false
            end)
        end
    end)
    setStat("Farm Subterraneo ON — Y=" .. SUB_Y .. " | Velocidade "..farmSpeed, C.vd)
end

-- ============================================================
-- BURACOS DO MAPA (CORRIGIDO COM ANTI-VOID)
-- ============================================================
local buraco_Y = -7
local buraco_orig = nil
local buracoConn = nil
local noBuraco = false
local antiVoidConn = nil

local function initAntiVoid()
    if antiVoidConn then antiVoidConn:Disconnect() end
    antiVoidConn = RS.Stepped:Connect(function()
        local h = getHRP()
        if h and h.Position.Y < 0 then
            h.CFrame = CFrame.new(h.Position.X, 5, h.Position.Z)
            setStat("Anti-Void: evitando queda infinita!", C.am)
        end
    end)
end

local function irParaBuraco()
    if noBuraco then setStat("Ja esta num buraco!", C.am); return end
    local h = getHRP(); if not h then return end
    buraco_orig = h.Position
    local holePart = findObj({"hole", "gap", "void", "transition", "portal", "abyss", "lacuna"})
    if holePart then
        tpTo(getPos(holePart))
        setStat("Teleportado para o buraco real!", C.vd)
    else
        local gapX = h.Position.X + 80
        h.CFrame = CFrame.new(gapX, buraco_Y, h.Position.Z)
        setStat("Teleporte alternativo para o buraco!", C.am)
    end
    noBuraco = true
    initAntiVoid()
    if buracoConn then buracoConn:Disconnect() end
    buracoConn = RS.Stepped:Connect(function()
        if not noBuraco then buracoConn:Disconnect(); buracoConn = nil; return end
        local h2 = getHRP(); if not h2 then return end
        if h2.Position.Y < buraco_Y - 2 or h2.Position.Y > buraco_Y + 3 then
            pcall(function() h2.CFrame = CFrame.new(h2.Position.X, buraco_Y, h2.Position.Z) end)
        end
    end)
    setStat("Dentro do buraco! Y=" .. buraco_Y .. " | Toque Sair Buraco para voltar", C.vd)
end

local function sairDoBuraco()
    noBuraco = false
    if buracoConn then buracoConn:Disconnect(); buracoConn = nil end
    if antiVoidConn then antiVoidConn:Disconnect(); antiVoidConn = nil end
    local h = getHRP()
    if h then
        if buraco_orig then h.CFrame = CFrame.new(buraco_orig.X, 5, buraco_orig.Z)
        else h.CFrame = CFrame.new(h.Position.X, 5, h.Position.Z) end
    end
    buraco_orig = nil
    setStat("Voltou para a superficie!", C.vd)
end

-- ============================================================
-- METODOS DE PROTECAO (ANTI-HIT, BYPASS, SAFE ZONE, LAG GLITCH, FANTASMA)
-- ============================================================
local antiHitConn = nil
local function fAntiHit(on)
    if antiHitConn then antiHitConn:Disconnect(); antiHitConn = nil end
    if not on then setStat("Anti-Hit OFF", C.vm); return end
    local waveKws = {"tsunami","wave","flood","water","bunny","rabbit","tidal","surge","kill"}
    local function removerHitbox()
        for _, o in pairs(WS:GetDescendants()) do
            local n = o.Name:lower()
            for _, k in pairs(waveKws) do
                if n:find(k) and o:IsA("BasePart") then
                    pcall(function() o.CanCollide = false end)
                end
            end
        end
    end
    removerHitbox()
    antiHitConn = RS.Stepped:Connect(removerHitbox)
    setStat("Anti-Hit ON — hitbox da onda removida!", C.vd)
end

local function fBypassDano(on)
    if not on then setStat("Bypass Dano OFF", C.vm); return end
    local count = 0
    local function disable(char)
        if not char then return end
        for _, s in pairs(char:GetDescendants()) do
            if (s:IsA("LocalScript") or s:IsA("Script")) then
                local n = s.Name:lower()
                if n:find("health") or n:find("damage") or n:find("hurt") then
                    pcall(function() s.Disabled = true end); count = count + 1
                end
            end
        end
        pcall(function()
            for _, s in pairs(game:GetService("StarterPlayer"):GetDescendants()) do
                if (s:IsA("LocalScript") or s:IsA("Script")) and s.Name:lower():find("health") then
                    s.Disabled = true; count = count + 1
                end
            end
        end)
    end
    disable(getChar())
    LP.CharacterAdded:Connect(function(nc) task.wait(0.3); disable(nc) end)
    setStat("Bypass Dano ON — " .. count .. " scripts desativados!", C.vd)
end

local safeZoneConn = nil
local safeZoneLocked = false
local SAFE_Y = 120
local function fSafeZone(on)
    if safeZoneConn then safeZoneConn:Disconnect(); safeZoneConn = nil end
    if not on then setStat("Safe Zone OFF", C.vm); return end
    safeZoneConn = RS.Heartbeat:Connect(function()
        local h = getHRP(); if not h or safeZoneLocked then return end
        local wave = WS:FindFirstChild("Tsunami") or WS:FindFirstChild("Wave") or findObj({"tsunami","wave","flood","bunny"})
        if wave then
            local wp = wave:IsA("Model") and wave.PrimaryPart or (wave:IsA("BasePart") and wave)
            if wp and wp:IsA("BasePart") and (h.Position - wp.Position).Magnitude < 180 then
                safeZoneLocked = true
                local orig = h.Position
                h.CFrame = CFrame.new(orig.X, SAFE_Y, orig.Z)
                task.delay(0.08, function()
                    local h2 = getHRP()
                    if h2 then h2.CFrame = CFrame.new(orig) end
                    task.delay(0.3, function() safeZoneLocked = false end)
                end)
                setStat("Safe Zone: TP instantaneo!", C.am)
            end
        end
    end)
    setStat("Safe Zone ON — TP anti-tsunami ativo!", C.vd)
end

local lagConn = nil
local frozenWaves = {}
local function fLagGlitch(on)
    if lagConn then lagConn:Disconnect(); lagConn = nil end
    frozenWaves = {}
    if not on then setStat("Lag Glitch OFF", C.vm); return end
    lagConn = RS.Stepped:Connect(function()
        for _, o in pairs(WS:GetDescendants()) do
            local n = o.Name:lower()
            if (n:find("tsunami") or n:find("wave") or n:find("flood")) and o:IsA("BasePart") then
                if not frozenWaves[o] then frozenWaves[o] = o.CFrame end
            end
        end
        for wave, cf in pairs(frozenWaves) do
            if wave and wave.Parent then
                pcall(function() wave.CFrame = cf; wave.CanCollide = false end)
            else
                frozenWaves[wave] = nil
            end
        end
    end)
    setStat("Lag Glitch ON — ondas congeladas!", C.vd)
end

local fantasmaConn = nil
local function fFantasma(on)
    if fantasmaConn then fantasmaConn:Disconnect(); fantasmaConn = nil end
    if not on then
        local c = getChar()
        if c then
            for _, p in pairs(c:GetDescendants()) do
                if p:IsA("BasePart") then p.Transparency = 0; p.CanCollide = true end
            end
        end
        setStat("Fantasma OFF", C.vm); return
    end
    fantasmaConn = RS.Stepped:Connect(function()
        local c = getChar(); if not c then return end
        local h = getHRP()
        if h and h.Position.Y < 0 then pcall(function() h.CFrame = CFrame.new(h.Position.X, 2, h.Position.Z) end)
        for _, p in pairs(c:GetDescendants()) do
            if p:IsA("BasePart") then
                p.CanCollide = false
                if p.Name ~= "HumanoidRootPart" then p.Transparency = 0.45 end
            end
        end
    end)
    setStat("Fantasma ON — ondas passam por voce!", C.vd)
end

-- ============================================================
-- FLY + AUTO FARM (ORIGINAL)
-- ============================================================
local flyFarmConn = nil
local FLY_HEIGHT = 35
local function fFlyFarm(on)
    if flyFarmConn then flyFarmConn:Disconnect(); flyFarmConn = nil end
    if not on then
        local h = getHRP()
        if h then
            local bv = h:FindFirstChild("WHFfBv"); if bv then bv:Destroy() end
            local bg = h:FindFirstChild("WHFfBg"); if bg then bg:Destroy() end
        end
        local hm = getHum(); if hm then hm.PlatformStand = false end
        setStat("Fly+Farm OFF", C.vm); return
    end
    local h = getHRP(); if not h then return end
    local hm = getHum(); if hm then hm.PlatformStand = true end
    local bg = Instance.new("BodyGyro", h)
    bg.Name = "WHFfBg"; bg.MaxTorque = Vector3.new(9e9,9e9,9e9); bg.D = 100; bg.P = 1e5
    local bv = Instance.new("BodyVelocity", h)
    bv.Name = "WHFfBv"; bv.MaxForce = Vector3.new(9e9,9e9,9e9); bv.Velocity = Vector3.new()
    task.delay(0.2, function()
        local h2 = getHRP(); if h2 then h2.CFrame = CFrame.new(h2.Position.X, FLY_HEIGHT, h2.Position.Z) end
    end)
    local farmKws = {
        "brainrot","common","uncommon","rare","epic","legendary","mythic",
        "cosmic","secret","celestial","divine","infinity","paradox",
        "phantom","orb","coin","shard","fish","ore","gem","crystal",
        "egg","spring","golden","lucky","block","collect","pickup","drop"
    }
    flyFarmConn = RS.Stepped:Connect(function()
        local h3 = getHRP(); if not h3 then return end
        local bv2 = h3:FindFirstChild("WHFfBv")
        if bv2 then
            bv2.Velocity = h3.Position.Y < FLY_HEIGHT - 3 and Vector3.new(0, 40, 0) or Vector3.new(0, 0, 0)
        end
        for _, o in pairs(WS:GetDescendants()) do
            local n = o.Name:lower()
            for _, k in pairs(farmKws) do
                if n:find(k) then
                    local pos = getPos(o)
                    if pos then
                        local xzDist = Vector2.new(h3.Position.X - pos.X, h3.Position.Z - pos.Z).Magnitude
                        if xzDist < 150 then
                            h3.CFrame = CFrame.new(pos.X, FLY_HEIGHT, pos.Z)
                            activateObj(o)
                        end
                    end; break
                end
            end
        end
    end)
    setStat("Fly+Farm ON — voando em Y=" .. FLY_HEIGHT .. "!", C.vd)
end

-- ============================================================
-- MONEY FARM (ORIGINAL)
-- ============================================================
local function fMoneyFarm(on)
    stopLoop("mf"); if not on then setStat("Money Farm OFF", C.vm); return end
    spawn(function()
        while toggleStates["Money Farm"] do
            local h = getHRP()
            if h then
                for _, o in pairs(WS:GetDescendants()) do
                    local n = o.Name:lower()
                    if n:find("orb") or n:find("coin") or n:find("money") or n:find("earn") or n:find("slot") or n:find("pad") or n:find("base") then
                        local pos = getPos(o)
                        if pos then
                            local h2 = getHRP(); if not h2 then break end
                            h2.CFrame = CFrame.new(pos.X, h2.Position.Y, pos.Z)
                            task.wait(0.06); activateObj(o)
                        end
                    end
                end
            end
            task.wait(1.5)
        end
    end)
    setStat("Money Farm ON — percorrendo base!", C.vd)
end

-- ============================================================
-- GHOST COLLECT (ORIGINAL)
-- ============================================================
local function ghostCollect(keyword, displayName, stateName)
    spawn(function()
        while toggleStates[stateName] do
            local h = getHRP()
            if h then
                local found = {}
                for _, o in pairs(WS:GetDescendants()) do
                    if o.Name:lower():find(keyword) then
                        local pos = getPos(o)
                        if pos then found[#found + 1] = {o = o, p = pos} end
                    end
                end
                if #found > 0 then
                    setStat("Coletando: " .. displayName, C.am)
                    for _, item in pairs(found) do
                        if not toggleStates[stateName] then break end
                        local h2 = getHRP(); if not h2 then break end
                        h2.CFrame = CFrame.new(item.p + Vector3.new(0, 3, 0))
                        task.wait(0.12); activateObj(item.o)
                    end
                    local base = findObj({"base","plot","spawn","homebase"})
                    local bp = getPos(base)
                    local h3 = getHRP()
                    if h3 and bp then h3.CFrame = CFrame.new(bp + Vector3.new(0, 4, 0)) end
                    setStat(displayName .. " coletado! Base.", C.vd)
                else
                    setStat("Procurando " .. displayName .. "...", C.txs)
                end
            end
            task.wait(2.5)
        end
    end)
end

