-- ============================================================
-- MINING EVENT (ORIGINAL)
-- ============================================================
local function fMining(on)
    stopLoop("mine"); if not on then return end
    spawn(function()
        while toggleStates["Auto Mining"] do
            local h = getHRP()
            if h then
                local best, bestDist = nil, 999
                for _, o in pairs(WS:GetDescendants()) do
                    local n = o.Name:lower()
                    if n:find("rock") or n:find("ore") or n:find("gem") or n:find("mineral") or n:find("vein") then
                        local pos = getPos(o)
                        if pos then
                            local d = (h.Position - pos).Magnitude
                            if d < bestDist then bestDist = d; best = {o = o, p = pos} end
                        end
                    end
                end
                if best then
                    h.CFrame = CFrame.new(best.p + Vector3.new(0, 3, 0))
                    task.wait(0.15); activateObj(best.o)
                    task.wait(0.3)
                    for _, o in pairs(WS:GetDescendants()) do
                        local n = o.Name:lower()
                        if n:find("gem") or n:find("drop") or n:find("crystal") then
                            local pos = getPos(o)
                            if pos then
                                local h2 = getHRP()
                                if h2 then
                                    h2.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0))
                                    activateObj(o)
                                end
                            end
                        end
                    end
                end
            end
            task.wait(1)
        end
    end)
end

-- ============================================================
-- CANCEL TSUNAMI (ORIGINAL)
-- ============================================================
local cancelTsConn = nil
local function fCancelTs(on)
    if cancelTsConn then cancelTsConn:Disconnect(); cancelTsConn = nil end
    if not on then setStat("Cancel Tsunami OFF", C.vm); return end
    local waveKws = {"tsunami","wave","flood","tidal","bunny","rabbit"}
    local function removeWaves()
        for _, o in pairs(WS:GetDescendants()) do
            local n = o.Name:lower()
            for _, k in pairs(waveKws) do
                if n:find(k) then
                    if o:IsA("BasePart") then
                        pcall(function() o.CanCollide = false; o.Transparency = 1; o.CFrame = CFrame.new(0,-9999,0) end)
                    elseif o:IsA("Model") then
                        for _, p in pairs(o:GetDescendants()) do
                            if p:IsA("BasePart") then
                                pcall(function() p.CanCollide = false; p.Transparency = 1; p.CFrame = CFrame.new(0,-9999,0) end)
                            end
                        end
                    end
                end
            end
        end
    end
    removeWaves()
    cancelTsConn = RS.Stepped:Connect(removeWaves)
    setStat("Tsunami CANCELADO — ondas removidas!", C.vd)
end

-- ============================================================
-- AUTO ESCAPE (ORIGINAL)
-- ============================================================
local function fAutoEscape(on)
    stopLoop("esc"); if not on then return end
    loops["esc"] = RS.Stepped:Connect(function()
        local h = getHRP(); if not h then return end
        local wave = WS:FindFirstChild("Tsunami") or WS:FindFirstChild("Wave") or findObj({"tsunami","wave","flood","bunny"})
        if wave then
            local wp = wave:IsA("Model") and wave.PrimaryPart or (wave:IsA("BasePart") and wave)
            if wp and wp:IsA("BasePart") and (h.Position - wp.Position).Magnitude < 240 then
                local dir = (h.Position - wp.Position).Unit
                h.CFrame = h.CFrame + (dir * 150)
                setStat("Fugindo da onda!", C.vm)
            end
        end
    end)
end

-- ============================================================
-- FLY NORMAL (ORIGINAL)
-- ============================================================
local flyNormConn = nil
local function stopFlyNorm()
    if flyNormConn then flyNormConn:Disconnect(); flyNormConn = nil end
    local h = getHRP()
    if h then
        local bg = h:FindFirstChild("WHBg"); if bg then bg:Destroy() end
        local bv = h:FindFirstChild("WHBv"); if bv then bv:Destroy() end
    end
    local hm = getHum(); if hm then hm.PlatformStand = false end
    local fu = SG:FindFirstChild("FlyUI"); if fu then fu:Destroy() end
end
local function fFlyNorm(on)
    stopFlyNorm(); if not on then setStat("Fly OFF", C.vm); return end
    local h = getHRP(); if not h then return end
    local hm = getHum(); if hm then hm.PlatformStand = true end
    local bg = Instance.new("BodyGyro", h); bg.Name = "WHBg"; bg.MaxTorque = Vector3.new(9e9,9e9,9e9); bg.D = 100; bg.P = 1e5
    local bv = Instance.new("BodyVelocity", h); bv.Name = "WHBv"; bv.MaxForce = Vector3.new(9e9,9e9,9e9); bv.Velocity = Vector3.new()
    local fu = Instance.new("Frame", SG); fu.Name = "FlyUI"; fu.Size = UDim2.new(0,190,0,108); fu.Position = UDim2.new(0.5,-95,1,-128); fu.BackgroundTransparency = 1; fu.ZIndex = 30
    local held = {}
    for _, d in pairs({{"Subir",0.37,0,Vector3.new(0,1,0)},{"Descer",0.37,0.65,Vector3.new(0,-1,0)},{"Esq",0,0.32,"left"},{"Dir",0.72,0.32,"right"},{"Frente",0.37,0.32,"front"}}) do
        local b = Instance.new("TextButton",fu); b.Size=UDim2.new(0,54,0,30); b.Position=UDim2.new(d[2],0,d[3],0); b.BackgroundColor3=C.rx; b.Text=d[1]; b.TextColor3=C.br; b.TextSize=10; b.Font=Enum.Font.GothamBold; b.BorderSizePixel=0; b.ZIndex=31; cr(b,6)
        b.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseButton1 then held[d[1]]=d[4] end end)
        b.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseButton1 then held[d[1]]=nil end end)
    end
    local sb = Instance.new("TextButton",fu); sb.Size=UDim2.new(1,0,0,22); sb.Position=UDim2.new(0,0,1,-24); sb.BackgroundColor3=C.rx; sb.Text="PARAR FLY"; sb.TextColor3=C.br; sb.TextSize=10; sb.Font=Enum.Font.GothamBold; sb.BorderSizePixel=0; sb.ZIndex=31; cr(sb,5)
    sb.MouseButton1Click:Connect(function() toggleStates["Fly"]=false; stopFlyNorm(); setStat("Fly OFF",C.vm) end)
    flyNormConn = RS.Heartbeat:Connect(function()
        local h2 = getHRP(); if not h2 then stopFlyNorm(); return end
        local bv2 = h2:FindFirstChild("WHBv"); local bg2 = h2:FindFirstChild("WHBg"); if not bv2 or not bg2 then return end
        local cam = WS.CurrentCamera; local dir = Vector3.new()
        for _, v in pairs(held) do
            if type(v) == "userdata" then dir = dir + v
            elseif v == "front" then dir = dir + cam.CFrame.LookVector
            elseif v == "left" then dir = dir - cam.CFrame.RightVector
            elseif v == "right" then dir = dir + cam.CFrame.RightVector end
        end
        if UIS:IsKeyDown(Enum.KeyCode.W) then dir = dir + cam.CFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.S) then dir = dir - cam.CFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.A) then dir = dir - cam.CFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.D) then dir = dir + cam.CFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.Space) then dir = dir + Vector3.new(0,1,0) end
        if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then dir = dir - Vector3.new(0,1,0) end
        bv2.Velocity = dir.Magnitude > 0 and dir.Unit * 62 or Vector3.new()
        bg2.CFrame = cam.CFrame
    end)
    setStat("Fly ON! Use botoes ou WASD", C.vd)
end

-- ============================================================
-- FULLBRIGHT (ORIGINAL)
-- ============================================================
local function fFullBright(on)
    if on then LT.Brightness=10; LT.ClockTime=14; LT.FogEnd=1e9; LT.GlobalShadows=false; LT.Ambient=Color3.fromRGB(255,255,255)
    else LT.Brightness=2; LT.ClockTime=14; LT.FogEnd=100000; LT.GlobalShadows=true; LT.Ambient=Color3.fromRGB(100,100,100) end
    setStat(on and "FullBright ON" or "FullBright OFF", on and C.vd or C.vm)
end

-- ============================================================
-- NOCLIP (ORIGINAL)
-- ============================================================
local function fNoclip(on)
    stopLoop("nc"); if not on then return end
    loops["nc"] = RS.Stepped:Connect(function()
        local c = getChar(); if not c then return end
        for _, p in pairs(c:GetDescendants()) do
            if p:IsA("BasePart") then p.CanCollide = false end
        end
    end)
end

-- ============================================================
-- INFINITE JUMP (ORIGINAL)
-- ============================================================
local function fInfJump(on)
    stopLoop("ij"); if not on then return end
    loops["ij"] = UIS.JumpRequest:Connect(function()
        local hm = getHum(); if hm then hm:ChangeState(Enum.HumanoidStateType.Jumping) end
    end)
end

-- ============================================================
-- ESP (ORIGINAL)
-- ============================================================
local function fESP(on)
    if not on then
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LP and p.Character then
                local bb = p.Character:FindFirstChild("WHESP"); if bb then bb:Destroy() end
            end
        end; return
    end
    local function addESP(p)
        if not p.Character then p.CharacterAdded:Wait() end
        local c = p.Character; if not c then return end
        local bb = Instance.new("BillboardGui", c); bb.Name="WHESP"; bb.Size=UDim2.new(0,100,0,26); bb.StudsOffset=Vector3.new(0,3,0); bb.AlwaysOnTop=true
        local l = lbl(bb, p.Name, 10, C.dt, Enum.Font.GothamBold, 1)
        l.Size=UDim2.new(1,0,1,0); l.BackgroundColor3=Color3.new(0,0,0); l.BackgroundTransparency=0.6; cr(l,4)
    end
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LP then spawn(function() addESP(p) end) end
    end
end

-- ============================================================
-- ANTI-BAC (ORIGINAL)
-- ============================================================
local function startAntiBAC()
    spawn(function()
        while true do
            task.wait(38 + math.random(1, 26))
            if toggleStates["Anti-Deteccao"] then
                local hm = getHum()
                if hm and math.random(1, 3) == 1 then
                    hm.Jump = true
                    task.delay(0.06 + math.random() * 0.05, function()
                        if hm then hm.Jump = false end
                    end)
                end
            end
        end
    end)
end

-- ============================================================
-- NOVAS FUNCOES DO EVENTO DA FOICE (JUNGLE EVENT)
-- ============================================================

-- Tabela de prioridade de raridades (conforme lista oficial de Abril 2026)[reference:1]
-- Infinity (mais raro) > Divine > Celestial > Secret > Cosmic > Mythical > Legendary > Epic > Rare > Uncommon > Common
local rarityPriority = {
    ["infinity"] = 11,
    ["divine"] = 10,
    ["celestial"] = 9,
    ["secret"] = 8,
    ["cosmic"] = 7,
    ["mythical"] = 6,
    ["mythic"] = 6,
    ["legendary"] = 5,
    ["epic"] = 4,
    ["rare"] = 3,
    ["uncommon"] = 2,
    ["common"] = 1,
}

-- Força Infinita para a Foice (versão otimizada)
local function applyInfiniteScytheDamage()
    local char = getChar()
    if not char then return end
    local tool = char:FindFirstChildWhichIsA("Tool")
    if not tool then return end
    
    -- Tenta diferentes remotes para garantir o dano
    local remote = RC:FindFirstChild("SwingAttack") or RC:FindFirstChild("CutGrass") or RC:FindFirstChild("Damage") or RC:FindFirstChild("DealDamage")
    if remote then
        for i = 1, 25 do
            if not toggleStates["Forca Infinita Scythe"] then break end
            remote:FireServer(tool, {damage = 9999999, hits = 99})
            task.wait(0.01)
        end
    end
    
    -- Fallback: ativar prompt de corte
    local grass = findObj({"grass", "blade", "bush", "weed", "vine"})
    if grass then
        activateObj(grass)
    end
end

-- Auto Farm Scythe com prioridade por raridade e quebra de matos
local function autoFarmScytheLoop()
    while toggleStates["Auto Farm Scythe (Loop Completo)"] do
        local hrp = getHRP()
        if not hrp then task.wait(1) end
        
        -- 1. PROCURAR BRAINROTS RAROS (prioridade máxima)
        local bestRarity = nil
        local bestRarityScore = -1
        local bestRarityPos = nil
        local bestRarityObj = nil
        
        for _, item in pairs(WS:GetDescendants()) do
            local n = item.Name:lower()
            for rarity, score in pairs(rarityPriority) do
                if n:find(rarity) and (n:find("brainrot") or n:find("collect") or n:find("pickup")) then
                    local pos = getPos(item)
                    if pos then
                        local dist = (hrp.Position - pos).Magnitude
                        if score > bestRarityScore then
                            bestRarityScore = score
                            bestRarity = rarity
                            bestRarityPos = pos
                            bestRarityObj = item
                        elseif score == bestRarityScore and dist < (bestRarityPos and (hrp.Position - bestRarityPos).Magnitude or 999) then
                            bestRarityPos = pos
                            bestRarityObj = item
                        end
                    end
                    break
                end
            end
        end
        
        -- Se encontrou um Brainrot raro, vai até ele
        if bestRarityObj and bestRarityPos then
            setStat("Indo buscar: " .. string.upper(bestRarity) .. " Brainrot", C.am)
            tpTo(bestRarityPos)
            task.wait(0.1)
            activateObj(bestRarityObj)
            
            -- Se houver matos bloqueando, corta rapidamente
            local obstacles = findObj({"grass", "bush", "weed", "vine", "tall grass"})
            if obstacles then
                for i = 1, 10 do
                    activateObj(obstacles)
                    if toggleStates["Forca Infinita Scythe"] then
                        applyInfiniteScytheDamage()
                    end
                    task.wait(0.05)
                end
            end
            task.wait(0.3)
            
            -- Leva para a base
            local base = findObj({"base", "delivery", "dropoff", "spawn"})
            if base then
                tpTo(getPos(base))
                task.wait(0.3)
                activateObj(base)
                setStat(bestRarity:upper() .. " entregue na base!", C.vd)
            end
            task.wait(0.5)
        end
        
        -- 2. CORTAR GRAMA E PEDRAS (abrir caminho)
        local target = findObj({"grass", "blade", "bush", "weed", "vine", "tall grass", "rock", "stone", "pedra"})
        if target then
            local pos = getPos(target)
            if pos then
                tpTo(pos)
                task.wait(0.05)
                activateObj(target)
                if toggleStates["Forca Infinita Scythe"] then
                    applyInfiniteScytheDamage()
                end
                task.wait(0.05)
            end
        end
        
        -- 3. COLETAR ITENS COMUNS (prioridade baixa)
        for _, item in pairs(WS:GetDescendants()) do
            local n = item.Name:lower()
            if (n:find("brainrot") or n:find("coin") or n:find("token") or n:find("shard")) then
                local isRare = false
                for rarity in pairs(rarityPriority) do
                    if n:find(rarity) and rarity ~= "common" and rarity ~= "uncommon" then
                        isRare = true
                        break
                    end
                end
                if not isRare then
                    local pos = getPos(item)
                    if pos and (hrp.Position - pos).Magnitude < 80 then
                        tpTo(pos)
                        activateObj(item)
                        task.wait(0.05)
                    end
                end
            end
        end
        
        -- 4. UPGRADES DA FOICE
        local upgrade = findObj({"upgrade", "shop", "store", "anvil", "smith"})
        if upgrade and toggleStates["Auto Upgrade Scythe"] then
            tpTo(getPos(upgrade))
            task.wait(0.3)
            for _, btn in pairs(upgrade:GetDescendants()) do
                if btn:IsA("TextButton") and (btn.Name:lower():find("damage") or btn.Name:lower():find("speed") or btn.Name:lower():find("purchase") or btn.Name:lower():find("buy")) then
                    fireclickdetector(btn)
                    task.wait(0.1)
                end
            end
        end
        
        -- 5. REBIRTH
        local rebirth = findObj({"rebirth", "prestige", "reset", "reincarnate"})
        if rebirth and toggleStates["Auto Rebirth"] then
            local text = rebirth:FindFirstChild("TextLabel")
            if text and text.Text:lower():find("available") then
                tpTo(getPos(rebirth))
                task.wait(0.3)
                activateObj(rebirth)
                setStat("Rebirth realizado! Foice mais poderosa!", C.am)
                task.wait(3)
            end
        end
        
        task.wait(0.2)
    end
end

-- Auto Cut Grass (apenas cortar matos e coletar itens comuns)
local function autoCutGrass()
    while toggleStates["Auto Cut Grass (Coletar)"] do
        local hrp = getHRP()
        if not hrp then task.wait(1) end
        
        local grass = findObj({"grass", "blade", "bush", "weed", "vine", "tall grass"})
        if grass then
            local pos = getPos(grass)
            if pos and (hrp.Position - pos).Magnitude < 60 then
                tpTo(pos)
                task.wait(0.05)
                activateObj(grass)
                if toggleStates["Forca Infinita Scythe"] then
                    applyInfiniteScytheDamage()
                end
                task.wait(0.05)
            end
        end
        
        for _, item in pairs(WS:GetDescendants()) do
            local n = item.Name:lower()
            if n:find("brainrot") or n:find("coin") or n:find("token") then
                local pos = getPos(item)
                if pos and (hrp.Position - pos).Magnitude < 50 then
                    tpTo(pos)
                    activateObj(item)
                    task.wait(0.05)
                end
            end
        end
        
        task.wait(0.15)
    end
end

-- Auto Upgrade Scythe
local function autoUpgradeScythe()
    while toggleStates["Auto Upgrade Scythe"] do
        local upgrade = findObj({"upgrade", "shop", "store", "anvil", "smith"})
        if upgrade then
            tpTo(getPos(upgrade))
            task.wait(0.3)
            for _, btn in pairs(upgrade:GetDescendants()) do
                if btn:IsA("TextButton") and (btn.Name:lower():find("damage") or btn.Name:lower():find("speed") or btn.Name:lower():find("purchase") or btn.Name:lower():find("buy")) then
                    fireclickdetector(btn)
                    task.wait(0.1)
                end
            end
        end
        task.wait(2)
    end
end

-- Auto Rebirth
local function autoRebirth()
    while toggleStates["Auto Rebirth"] do
        local rebirth = findObj({"rebirth", "prestige", "reset", "reincarnate"})
        if rebirth then
            local text = rebirth:FindFirstChild("TextLabel")
            if text and text.Text:lower():find("available") then
                tpTo(getPos(rebirth))
                task.wait(0.3)
                activateObj(rebirth)
                setStat("Auto Rebirth ativado! Foice renascida!", C.am)
                task.wait(3)
            end
        end
        task.wait(4)
    end
end

-- Teleporte para o Evento da Foice (Selva)
local function irParaEventoScythe()
    local portal = findObj({"grass", "field", "lobby", "jungle", "forest", "selva", "cut"}) or findObj({"scythe", "event"})
    if portal then
        tpTo(getPos(portal))
        setStat("Teleportado para a selva do evento da foice!", C.vd)
    else
        setStat("Evento da foice nao encontrado. Entre no jogo primeiro.", C.vm)
    end
end

-- ============================================================
-- FUNCOES DO CARNIVAL UPDATE (BASEADAS EM PESQUISA OFICIAL)
-- ============================================================
-- Fonte: Carnival Machine Guide - roonby.com[reference:2]
-- A Carnival Machine permite combinar Brainrots para aplicar mutações, duplicar, 
-- aumentar nível e obter a rara Showtime Mutation[reference:3]
-- O minigame de circles afeta a qualidade das recompensas[reference:4]

-- Auto Carnival Machine (executa o minigame automaticamente)
local function autoCarnivalMachine()
    while toggleStates["Auto Carnival Machine"] do
        local machine = findObj({"CarnivalMachine", "Carnival Machine", "PrizeMachine", "Carnival", "Machine"})
        if machine then
            tpTo(getPos(machine))
            task.wait(0.3)
            activateObj(machine)
            
            -- Simula o minigame de circles com timing perfeito
            if toggleStates["Auto Carnival Machine Full Auto"] then
                for i = 1, 8 do
                    pcall(function()
                        VIM:SendMouseButtonEvent(1, 500 + math.random(50, 400), 300 + math.random(50, 200), true, game, 0)
                        task.wait(math.random(1, 3) / 20)
                        VIM:SendMouseButtonEvent(1, 500 + math.random(50, 400), 300 + math.random(50, 200), false, game, 0)
                    end)
                    task.wait(math.random(3, 7) / 10)
                end
                setStat("Minigame Carnival executado! Possivel Showtime Mutation.", C.am)
            end
            task.wait(2)
        else
            task.wait(5)
        end
    end
end

-- Auto Dupe System (baseado em pesquisa de eventos UFO, Money, Arcade)
-- Fonte: Dupe guide rutab.net[reference:5], Portal do Pixel[reference:6]
-- Durante eventos UFO, Money ou Arcade, maquinas especiais permitem duplicar Brainrots[reference:7]
-- Para aumentar chances, server luck deve estar alta[reference:8]
local function autoDupeSystem()
    while toggleStates["Auto Dupe System"] do
        -- Procura máquinas de duplicação de eventos (UFO, Money, Arcade)
        local dupeMachine = findObj({"SpawnMachine", "UFOMachine", "MoneyMachine", "ArcadeMachine", "DupeMachine", "CraftMachine", "BlackHole", "ATM", "SlotMachine"})
        if dupeMachine then
            tpTo(getPos(dupeMachine))
            task.wait(0.5)
            activateObj(dupeMachine)
            task.wait(0.3)
            
            -- Procura botoes de deposito e craft
            for _, btn in pairs(dupeMachine.Parent:GetDescendants()) do
                if btn:IsA("TextButton") then
                    local txt = btn.Text:lower()
                    if txt:find("deposit") or txt:find("add") or txt:find("insert") then
                        fireclickdetector(btn)
                        task.wait(0.2)
                    elseif txt:find("craft") or txt:find("confirm") or txt:find("duplicate") or txt:find("dupe") then
                        fireclickdetector(btn)
                        task.wait(0.5)
                        setStat("Tentativa de duplicacao realizada!", C.vd)
                    end
                end
            end
        end
        task.wait(3)
    end
end

-- Auto Coleta de Event Coins (Carnival)
local function autoCollectEventCoins()
    while toggleStates["Auto Collect Event Coins"] do
        local hrp = getHRP()
        if not hrp then task.wait(1) end
        
        for _, coin in pairs(WS:GetDescendants()) do
            local n = coin.Name:lower()
            if n:find("coin") or n:find("carnival") or n:find("eventcoin") or n:find("token") then
                local pos = getPos(coin)
                if pos and (hrp.Position - pos).Magnitude < 80 then
                    tpTo(pos)
                    activateObj(coin)
                    task.wait(0.05)
                end
            end
        end
        task.wait(1)
    end
end

-- Auto Spin Carnival Wheel
local function autoSpinCarnivalWheel()
    while toggleStates["Auto Spin Carnival Wheel"] do
        local wheel = findObj({"wheel", "spinner", "roulette", "roleta", "carnivalwheel", "prizewheel"})
        if wheel then
            tpTo(getPos(wheel))
            task.wait(0.3)
            activateObj(wheel)
            setStat("Girando a roda do Carnival!", C.am)
            task.wait(3)
        else
            task.wait(5)
        end
    end
end

