FBTN.BackgroundColor3 = C.rx
FBTN.Text = "W"
FBTN.TextSize = 19
FBTN.Font = Enum.Font.GothamBold
FBTN.TextColor3 = C.br
FBTN.BorderSizePixel = 0
FBTN.ZIndex = 21
cr(FBTN, 24)
mk(FBTN, C.dt, 2)
gr(FBTN, C.rx2, C.rxe)

local fabDrag, fabDragStart, fabStartPos, fabMoved = false, nil, nil, false
FBTN.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then
        fabDrag = true
        fabMoved = false
        fabDragStart = i.Position
        fabStartPos = FAB.Position
    end
end)
FBTN.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then
        fabDrag = false
    end
end)
UIS.InputChanged:Connect(function(i)
    if fabDrag and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
        local d = i.Position - fabDragStart
        if d.Magnitude > 5 then
            fabMoved = true
        end
        FAB.Position = UDim2.new(fabStartPos.X.Scale, fabStartPos.X.Offset + d.X, fabStartPos.Y.Scale, fabStartPos.Y.Offset + d.Y)
    end
end)

