local flyNormConn = nil
local function stopFlyNorm()
    if flyNormConn then
        flyNormConn:Disconnect()
        flyNormConn = nil
    end
    local h = getHRP()
    if h then
        local bg = h:FindFirstChild("WHBg")
        if bg then
            bg:Destroy()
        end
        local bv = h:FindFirstChild("WHBv")
        if bv then
            bv:Destroy()
        end
    end
    local hm = getHum()
    if hm then
        hm.PlatformStand = false
    end
    local fu = SG:FindFirstChild("FlyUI")
    if fu then
        fu:Destroy()
    end
end
local function fFlyNorm(on)
    stopFlyNorm()
    if not on then
        setStat("Fly OFF", C.vm)
        return
    end
    local h = getHRP()
    if not h then
        return
    end
    local hm = getHum()
    if hm then
        hm.PlatformStand = true
    end
    local bg = Instance.new("BodyGyro", h)
    bg.Name = "WHBg"
    bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
    bg.D = 100
    bg.P = 1e5
    local bv = Instance.new("BodyVelocity", h)
    bv.Name = "WHBv"
    bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
    bv.Velocity = Vector3.new()
    local fu = Instance.new("Frame", SG)
    fu.Name = "FlyUI"
    fu.Size = UDim2.new(0, 190, 0, 108)
    fu.Position = UDim2.new(0.5, -95, 1, -128)
    fu.BackgroundTransparency = 1
    fu.ZIndex = 30
    local held = {}
    for _, d in pairs({{"Subir", 0.37, 0, Vector3.new(0, 1, 0)}, {"Descer", 0.37, 0.65, Vector3.new(0, -1, 0)}, {"Esq", 0, 0.32, "left"}, {"Dir", 0.72, 0.32, "right"}, {"Frente", 0.37, 0.32, "front"}}) do
        local b = Instance.new("TextButton", fu)
        b.Size = UDim2.new(0, 54, 0, 30)
        b.Position = UDim2.new(d[2], 0, d[3], 0)
        b.BackgroundColor3 = C.rx
        b.Text = d[1]
        b.TextColor3 = C.br
        b.TextSize = 10
        b.Font = Enum.Font.GothamBold
        b.BorderSizePixel = 0
        b.ZIndex = 31
        cr(b, 6)
        b.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then
                held[d[1]] = d[4]
            end
        end)
        b.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then
                held[d[1]] = nil
            end
        end)
    end
    local sb = Instance.new("TextButton", fu)
    sb.Size = UDim2.new(1, 0, 0, 22)
    sb.Position = UDim2.new(0, 0, 1, -24)
    sb.BackgroundColor3 = C.rx
    sb.Text = "PARAR FLY"
    sb.TextColor3 = C.br
    sb.TextSize = 10
    sb.Font = Enum.Font.GothamBold
    sb.BorderSizePixel = 0
    sb.ZIndex = 31
    cr(sb, 5)
    sb.MouseButton1Click:Connect(function()
        toggleStates["Fly"] = false
        stopFlyNorm()
        setStat("Fly OFF", C.vm)
    end)
    flyNormConn = RS.Heartbeat:Connect(function()
        local h2 = getHRP()
        if not h2 then
            stopFlyNorm()
            return
        end
        local bv2 = h2:FindFirstChild("WHBv")
        local bg2 = h2:FindFirstChild("WHBg")
        if not bv2 or not bg2 then
            return
        end
        local cam = workspace.CurrentCamera
        local dir = Vector3.new()
        for _, v in pairs(held) do
            if type(v) == "userdata" then
                dir = dir + v
            elseif v == "front" then
                dir = dir + cam.CFrame.LookVector
            elseif v == "left" then
                dir = dir - cam.CFrame.RightVector
            elseif v == "right" then
                dir = dir + cam.CFrame.RightVector
            end
        end
        if UIS:IsKeyDown(Enum.KeyCode.W) then
            dir = dir + cam.CFrame.LookVector
        end
        if UIS:IsKeyDown(Enum.KeyCode.S) then
            dir = dir - cam.CFrame.LookVector
        end
        if UIS:IsKeyDown(Enum.KeyCode.A) then
            dir = dir - cam.CFrame.RightVector
        end
        if UIS:IsKeyDown(Enum.KeyCode.D) then
            dir = dir + cam.CFrame.RightVector
        end
        if UIS:IsKeyDown(Enum.KeyCode.Space) then
            dir = dir + Vector3.new(0, 1, 0)
        end
        if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then
            dir = dir - Vector3.new(0, 1, 0)
        end
        bv2.Velocity = dir.Magnitude > 0 and dir.Unit * 62 or Vector3.new()
        bg2.CFrame = cam.CFrame
    end)
    setStat("Fly ON! Use botoes ou WASD", C.vd)
end

