-- Força Infinita para a Foice (dano extremo)
local infiniteScytheConn = nil
local function applyInfiniteScytheDamage()
    local char = getChar()
    if not char then
        return
    end
    local tool = char:FindFirstChildWhichIsA("Tool")
    if not tool then
        return
    end
    local remote = RC:FindFirstChild("SwingAttack") or RC:FindFirstChild("CutGrass") or RC:FindFirstChild("Damage")
    if remote then
        for i = 1, 20 do
            if not toggleStates["Força Infinita Scythe"] then
                break
            end
            remote:FireServer(tool, {damage = 9999999})
            task.wait(0.02)
        end
    else
        local grass = findObj({"grass", "blade", "bush"})
        if grass then
            activateObj(grass)
        end
    end
end

-- Auto Farm Scythe (Loop Completo)
local function autoFarmScytheLoop()
    while toggleStates["Auto Farm Scythe (Loop Completo)"] do
        local hrp = getHRP()
        if not hrp then
            task.wait(1)
        end
        local target = findObj({"grass", "blade", "bush", "rock", "stone"})
        if target then
            local pos = getPos(target)
            if pos then
                tpTo(pos)
                task.wait(0.1)
                activateObj(target)
                if toggleStates["Força Infinita Scythe"] then
                    applyInfiniteScytheDamage()
                end
                task.wait(0.1)
            end
        end
        for _, item in pairs(workspace:GetDescendants()) do
            local n = item.Name:lower()
            if n:find("brainrot") or n:find("collect") or n:find("coin") then
                local pos = getPos(item)
                if pos and (hrp.Position - pos).Magnitude < 100 then
                    tpTo(pos)
                    activateObj(item)
                end
            end
        end
        local base = findObj({"base", "delivery", "dropoff"})
        if base then
            tpTo(getPos(base))
            task.wait(0.5)
            activateObj(base)
        end
        local upgrade = findObj({"upgrade", "shop", "store"})
        if upgrade then
            tpTo(getPos(upgrade))
            task.wait(0.5)
            for _, btn in pairs(upgrade:GetDescendants()) do
                if btn:IsA("TextButton") and (btn.Name:lower():find("damage") or btn.Name:lower():find("speed") or btn.Name:lower():find("purchase")) then
                    fireclickdetector(btn)
                    task.wait(0.1)
                end
            end
        end
        local rebirth = findObj({"rebirth", "prestige", "reset"})
        if rebirth then
            local text = rebirth:FindFirstChild("TextLabel")
            if text and text.Text:lower():find("available") then
                tpTo(getPos(rebirth))
                task.wait(0.5)
                activateObj(rebirth)
                setStat("Rebirth realizado! Foice renascida!", C.am)
                task.wait(3)
            end
        end
        task.wait(0.5)
    end
end

