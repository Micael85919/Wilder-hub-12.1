local pages = {}
local curPage = ""
local sideButtons = {}

local function showPage(name)
    for _, ch in pairs(ContentScroll:GetChildren()) do
        if ch:IsA("GuiObject") and ch ~= ContentLayout then
            ch:Destroy()
        end
    end
    for k, b in pairs(sideButtons) do
        if k == name then
            b.BackgroundColor3 = C.sel
            b.BackgroundTransparency = 0
        else
            b.BackgroundTransparency = 1
        end
    end
    curPage = name
    if pages[name] then
        for _, fn in pairs(pages[name]) do
            fn()
        end
    end
end

