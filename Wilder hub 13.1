-- SAFE ZONE TP
-- ============================================================
local safeZoneConn = nil
local safeZoneLocked = false
local SAFE_Y = 120
local function fSafeZone(on)
    if safeZoneConn then
        safeZoneConn:Disconnect()
        safeZoneConn = nil
    end
    if not on then
        setStat("Safe Zone OFF", C.vm)
        return
    end
    safeZoneConn = RS.Heartbeat:Connect(function()
        local h = getHRP()
        if not h or safeZoneLocked then
            return
        end
        local wave = workspace:FindFirstChild("Tsunami") or workspace:FindFirstChild("Wave") or findObj({"tsunami", "wave", "flood", "bunny"})
        if wave then
            local wp = wave:IsA("Model") and wave.PrimaryPart or (wave:IsA("BasePart") and wave)
            if wp and wp:IsA("BasePart") and (h.Position - wp.Position).Magnitude < 180 then
                safeZoneLocked = true
                local orig = h.Position
                h.CFrame = CFrame.new(orig.X, SAFE_Y, orig.Z)
                task.delay(0.08, function()
                    local h2 = getHRP()
                    if h2 then
                        h2.CFrame = CFrame.new(orig)
                    end
                    task.delay(0.3, function()
                        safeZoneLocked = false
                    end)
                end)
                setStat("Safe Zone: TP instantaneo!", C.am)
            end
        end
    end)
    setStat("Safe Zone ON — TP anti-tsunami ativo!", C.vd)
end

