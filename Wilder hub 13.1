-- ============================================================
-- BYPASS DANO
-- ============================================================
local function fBypassDano(on)
    if not on then
        setStat("Bypass Dano OFF", C.vm)
        return
    end
    local count = 0
    local function disable(char)
        if not char then
            return
        end
        for _, s in pairs(char:GetDescendants()) do
            if (s:IsA("LocalScript") or s:IsA("Script")) then
                local n = s.Name:lower()
                if n:find("health") or n:find("damage") or n:find("hurt") then
                    pcall(function()
                        s.Disabled = true
                    end)
                    count = count + 1
                end
            end
        end
        pcall(function()
            for _, s in pairs(game:GetService("StarterPlayer"):GetDescendants()) do
                if (s:IsA("LocalScript") or s:IsA("Script")) and s.Name:lower():find("health") then
                    s.Disabled = true
                    count = count + 1
                end
            end
        end)
    end
    disable(getChar())
    LP.CharacterAdded:Connect(function(nc)
        task.wait(0.3)
        disable(nc)
    end)
    setStat("Bypass Dano ON — " .. count .. " scripts desativados!", C.vd)
end

