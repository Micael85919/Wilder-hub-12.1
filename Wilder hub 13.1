-- GHOST COLLECT
-- ============================================================
local function ghostCollect(keyword, displayName, stateName)
    spawn(function()
        while toggleStates[stateName] do
            local h = getHRP()
            if h then
                local found = {}
                for _, o in pairs(workspace:GetDescendants()) do
                    if o.Name:lower():find(keyword) then
                        local pos = getPos(o)
                        if pos then
                            found[#found + 1] = {o = o, p = pos}
                        end
                    end
                end
                if #found > 0 then
                    setStat("Coletando: " .. displayName, C.am)
                    for _, item in pairs(found) do
                        if not toggleStates[stateName] then
                            break
                        end
                        local h2 = getHRP()
                        if not h2 then
                            break
                        end
                        h2.CFrame = CFrame.new(item.p + Vector3.new(0, 3, 0))
                        task.wait(0.12)
                        activateObj(item.o)
                    end
                    local base = findObj({"base", "plot", "spawn", "homebase"})
                    local bp = getPos(base)
                    local h3 = getHRP()
                    if h3 and bp then
                        h3.CFrame = CFrame.new(bp + Vector3.new(0, 4, 0))
                    end
                    setStat(displayName .. " coletado! Base.", C.vd)
                else
                    setStat("Procurando " .. displayName .. "...", C.txs)
                end
            end
            task.wait(2.5)
        end
    end)
end

