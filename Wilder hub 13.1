-- ============================================================
-- ESP
-- ============================================================
local function fESP(on)
    if not on then
        for _, p in pairs(game:GetService("Players"):GetPlayers()) do
            if p ~= LP and p.Character then
                local bb = p.Character:FindFirstChild("WHESP")
                if bb then
                    bb:Destroy()
                end
            end
        end
        return
    end
    local function addESP(p)
        if not p.Character then
            p.CharacterAdded:Wait()
        end
        local c = p.Character
        if not c then
            return
        end
        local bb = Instance.new("BillboardGui", c)
        bb.Name = "WHESP"
        bb.Size = UDim2.new(0, 100, 0, 26)
        bb.StudsOffset = Vector3.new(0, 3, 0)
        bb.AlwaysOnTop = true
        local l = lbl(bb, p.Name, 10, C.dt, Enum.Font.GothamBold, 1)
        l.Size = UDim2.new(1, 0, 1, 0)
        l.BackgroundColor3 = Color3.new(0, 0, 0)
        l.BackgroundTransparency = 0.6
        cr(l, 4)
    end
    for _, p in pairs(game:GetService("Players"):GetPlayers()) do
        if p ~= LP then
            spawn(function()
                addESP(p)
            end)
        end
    end
end

