-- ============================================================
local lagConn = nil
local frozenWaves = {}
local function fLagGlitch(on)
    if lagConn then
        lagConn:Disconnect()
        lagConn = nil
    end
    frozenWaves = {}
    if not on then
        setStat("Lag Glitch OFF", C.vm)
        return
    end
    lagConn = RS.Stepped:Connect(function()
        for _, o in pairs(workspace:GetDescendants()) do
            local n = o.Name:lower()
            if (n:find("tsunami") or n:find("wave") or n:find("flood")) and o:IsA("BasePart") then
                if not frozenWaves[o] then
                    frozenWaves[o] = o.CFrame
                end
            end
        end
        for wave, cf in pairs(frozenWaves) do
            if wave and wave.Parent then
                pcall(function()
                    wave.CFrame = cf
                    wave.CanCollide = false
                end)
            else
                frozenWaves[wave] = nil
            end
        end
    end)
    setStat("Lag Glitch ON — ondas congeladas!", C.vd)
end

