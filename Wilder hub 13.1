    local indicator = Instance.new("Frame", btn)
    indicator.Size = UDim2.new(0, 3, 0.6, 0)
    indicator.Position = UDim2.new(0, 0, 0.2, 0)
    indicator.BackgroundColor3 = C.dt
    indicator.BorderSizePixel = 0
    indicator.Visible = false
    indicator.ZIndex = 14
